# Single source of truth for all deployment configuration.
# Copy to deploy/.env and fill in your values.
# Run `make secrets` to auto-fill JWT_KEY and OPERATOR_PUB.
#
# The Makefile reads this file and generates:
#   deploy/terraform/terraform.tfvars   (from GCP_* / VM_* / domain vars)
#   deploy/ansible/inventory/hosts.yml  (from TF state + SSH_KEY)
# Ansible vars are passed directly as extra-vars — no manual editing needed.

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=                        # e.g. oast-mcp-prod
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
TF_BACKEND_BUCKET=                     # GCS bucket for Terraform state (must exist first)

# ── VM ────────────────────────────────────────────────────────────────────────
VM_MACHINE_TYPE=e2-micro               # e2-micro is free-tier eligible in us-central1
VM_DISK_SIZE_GB=20
VM_IMAGE=debian-cloud/debian-12
SSH_KEY=~/.ssh/id_ed25519                   # Ansible uses this; Terraform deploys SSH_KEY.pub to the VM
ADMIN_SSH_CIDR=                             # your egress IP: curl ifconfig.me → x.x.x.x/32

# ── Domain ────────────────────────────────────────────────────────────────────
# The VM is the authoritative nameserver for OAST_DOMAIN.
# Every random callback subdomain (e.g. a1b2c3.test1.oast.info) resolves to the VM
# and is recorded as an interaction event.
OAST_DOMAIN=                           # e.g. test1.oast.info

# The Cloud DNS managed zone that contains OAST_DOMAIN as a subdomain.
PARENT_DNS_ZONE_NAME=                  # e.g. oast-info  (zone for oast.info)

# MCP_HOSTNAME is the public HTTPS endpoint that AI assistants connect to
# for tool calls (SSE transport). It must be resolvable via Cloud DNS so that
# Caddy can obtain a TLS certificate via DNS-01 ACME challenge.
#
# AGENT_HOSTNAME is the public HTTPS/WebSocket endpoint that remote agents
# connect to for receiving tasks and uploading artifacts.
#
# IMPORTANT: both hostnames must be *siblings* of OAST_DOMAIN in the DNS
# hierarchy (same parent zone), NOT children. For example, if OAST_DOMAIN is
# test1.oast.info then valid values are mcp.oast.info and agent.oast.info.
# Using mcp.test1.oast.info would conflict with the NS delegation in Cloud DNS
# and prevent TLS certificates from being issued. See docs/domain-setup.md.
MCP_HOSTNAME=                          # e.g. mcp.oast.info
AGENT_HOSTNAME=                        # e.g. agent.oast.info

# ── TLS ───────────────────────────────────────────────────────────────────────
ACME_EMAIL=                            # real email for Let's Encrypt expiry notifications

# ── Secrets (auto-generated by: make secrets) ─────────────────────────────────
JWT_KEY=                               # 64 hex chars — openssl rand -hex 32
OPERATOR_PUB=                          # age1... public key (private key → deploy/operator.key)
TSIG_KEY_HEX=                          # 64 hex chars — TSIG secret shared between Caddy and oast-mcp

